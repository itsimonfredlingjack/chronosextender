{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chronos AI",
  "version": "0.1.0",
  "identifier": "dev.chronos.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Chronos AI",
        "width": 680,
        "height": 520,
        "minWidth": 480,
        "minHeight": 400,
        "visible": true,
        "url": "/dashboard"
      },
      {
        "label": "overlay",
        "title": "Chronos Overlay",
        "width": 500,
        "height": 400,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "center": true,
        "url": "/overlay"
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
